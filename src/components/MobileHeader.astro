---
interface Props {
    sortedFolders: string[];
}

const { sortedFolders } = Astro.props;
---

<header
    class="lg:hidden sticky top-0 z-50 bg-[var(--color-obsidian)] border-b border-[var(--color-structural)]"
>
    <div class="p-6 pb-2 text-center">
        <h1
            class="text-2xl font-serif font-bold tracking-tight text-white uppercase"
        >
            Anish Photography
        </h1>
    </div>

    {/* Horizontal Ticker Nav */}
    <nav
        class="overflow-x-auto no-scrollbar border-t border-[var(--color-structural)] bg-[var(--color-obsidian)]"
    >
        <ul class="flex whitespace-nowrap px-6 py-3 space-x-8">
            {
                sortedFolders.map((folder) => {
                    const slug = folder.toLowerCase().replace(/\s+/g, "-");
                    return (
                        <li>
                            <a
                                href={`#${slug}`}
                                class="nav-link block text-[10px] font-mono uppercase tracking-widest text-neutral-500 transition-colors duration-200 relative overflow-hidden group px-2 py-1"
                                data-target={slug}
                            >
                                <span class="absolute left-0 top-0 bottom-0 w-full opacity-10 pointer-events-none z-0">
                                    <span class="block h-full bg-[var(--color-trust)] w-0 transition-all duration-100 ease-linear nav-progress-bar" />
                                </span>
                                <span class="relative z-10">| {folder} |</span>
                            </a>
                        </li>
                    );
                })
            }
        </ul>
    </nav>
</header>

<script>
    // Smart Active State Progress for Mobile Header
    document.addEventListener("section-progress", ((e: CustomEvent) => {
        const { sectionId, progress } = e.detail;

        // Update matching mobile links
        document
            .querySelectorAll(
                `.nav-link[data-target="${sectionId}"] .nav-progress-bar`,
            )
            .forEach((el) => {
                (el as HTMLElement).style.width =
                    `${Math.max(0, Math.min(100, progress * 100))}%`;
            });

        // Reset others (handling global reset if Desktop sidebar doesn't cover it)
        document.querySelectorAll(".nav-progress-bar").forEach((el) => {
            const link = el.closest(".nav-link");
            if (link && link.getAttribute("data-target") !== sectionId) {
                (el as HTMLElement).style.width = "0%";
            }
        });
    }) as EventListener);
</script>

<style>
    /* Ticker Nav hiding scrollbar */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
