---
import StaticImage from "./StaticImage.astro";

interface Props {
    photo: any;
}

const { photo } = Astro.props;
const {
    url,
    key,
    width,
    height,
    make,
    model,
    dateTaken,
    fNumber,
    iso,
    exposureTime,
    lensModel,
    focalLength,
} = photo.data;

const camera = make && model ? `${make} ${model}` : model || make || "";
const date = new Date(dateTaken).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
const aperture = fNumber ? `f/${fNumber}` : "";
const isoVal = iso ? `ISO ${iso}` : "";
const shutter = exposureTime
    ? exposureTime < 1
        ? `1/${Math.round(1 / exposureTime)}`
        : `${exposureTime}s`
    : "";
const lens = lensModel || "";
const focalLen = focalLength ? `${Math.round(focalLength)}mm` : "";
const fileName = key.split("/").pop() || key;

const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
const scramble = (text: string) => {
    return text
        .split("")
        .map((char) => {
            if (char === " " || char === ".") return char;
            return chars[Math.floor(Math.random() * chars.length)];
        })
        .join("");
};
const scrambledFileName = scramble(fileName);
---

<div class="break-inside-avoid mb-8 relative group photo-card-wrapper">
    <a
        href={url}
        data-pswp-width={width || 2500}
        data-pswp-height={height || 1667}
        target="_blank"
        data-pswp-name={fileName}
        data-pswp-camera={camera}
        data-pswp-date={date}
        data-pswp-aperture={aperture}
        data-pswp-iso={isoVal}
        data-pswp-shutter={shutter}
        data-pswp-lens={lens}
        data-pswp-focal-length={focalLen}
        class="block bg-neutral-900 border border-neutral-800 transition-colors duration-300 sharp relative overflow-hidden cursor-crosshair photo-card-link"
    >
        {/* Main Image */}
        <div class="overflow-hidden relative z-0">
            <StaticImage
                src={url}
                alt={key}
                class="w-full h-auto block transition-opacity duration-300"
                imgClass="object-cover filter grayscale-0 contrast-110"
                loading="lazy"
                width={width}
                height={height}
            />
        </div>

        {/* HUD Overlay */}
        <div
            class="absolute inset-0 z-10 pointer-events-none p-4 flex flex-col justify-between opacity-0 group-hover:opacity-100 mobile-active:opacity-100 transition-opacity duration-500 bg-black/40"
        >
            {/* Top Row */}
            <div class="flex justify-between items-start">
                {/* Top Left Hairline */}
                <div class="relative pl-2 pt-2">
                    <div
                        class="absolute top-0 left-0 w-8 h-[1px] bg-[var(--color-trust)] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out"
                    >
                    </div>
                    <div
                        class="absolute top-0 left-0 w-[1px] h-8 bg-[var(--color-trust)] origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-500 delay-100 ease-out"
                    >
                    </div>
                    <span
                        class="text-[10px] font-mono text-white/90 tracking-widest uppercase block filename-scramble"
                        data-real-value={fileName}
                        data-scrambled={scrambledFileName}
                        >{scrambledFileName}</span
                    >
                </div>

                {/* Top Right Info */}
                <div class="text-right">
                    <span
                        class="block text-[10px] font-mono text-[var(--color-trust)] tracking-widest"
                        >{make}</span
                    >
                    <span
                        class="block text-[10px] font-sans font-bold text-white tracking-wide"
                        >{model}</span
                    >
                </div>
            </div>

            {/* Bottom Row */}
            <div class="flex justify-between items-end">
                {/* Tech Specs */}
                <div class="text-[10px] font-mono space-y-1 text-neutral-300">
                    <div class="flex gap-3">
                        <span class="text-neutral-500 w-12">ISO</span>
                        <span class="text-[var(--color-flash)]"
                            >{iso || "RAW"}</span
                        >
                    </div>
                    <div class="flex gap-3">
                        <span class="text-neutral-500 w-12">APERTURE</span>
                        <span class="text-[var(--color-flash)]"
                            >f/{fNumber}</span
                        >
                    </div>
                    <div class="flex gap-3">
                        <span class="text-neutral-500 w-12">SHUTTER</span>
                        <span class="text-[var(--color-flash)]">{shutter}</span>
                    </div>
                </div>

                {/* Bottom Right Hairline */}
                <div class="relative pr-2 pb-2">
                    <div
                        class="absolute bottom-0 right-0 w-8 h-[1px] bg-[var(--color-trust)] origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out"
                    >
                    </div>
                    <div
                        class="absolute bottom-0 right-0 w-[1px] h-8 bg-[var(--color-trust)] origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-500 delay-100 ease-out"
                    >
                    </div>
                </div>
            </div>
        </div>
    </a>

    {/* Loupe Container - Outside Link */}
    <div
        class="loupe-container fixed w-64 h-64 rounded-full border-2 border-[var(--color-trust)] shadow-2xl overflow-hidden pointer-events-none z-[100] hidden lg:block bg-black"
        style="display: none; transform: translate(-50%, -50%);"
    >
        <img
            data-src={url}
            class="absolute max-w-none object-cover"
            style="width: auto; height: auto;"
            id={`loupe-img-${String(Math.random()).slice(2)}`}
        />
    </div>
</div>

<script>
    const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";

    const unscrambleText = (element: HTMLElement) => {
        const originalText = element.getAttribute("data-real-value");
        if (!originalText) return;

        let iterations = 0;
        const interval = setInterval(() => {
            element.innerText = originalText
                .split("")
                .map((char, index) => {
                    if (index < iterations) {
                        return originalText[index];
                    }
                    return CHARS[Math.floor(Math.random() * CHARS.length)];
                })
                .join("");

            if (iterations >= originalText.length) {
                clearInterval(interval);
                element.innerText = originalText;
            }

            iterations += 1 / 3;
        }, 30);
    };

    const initCards = () => {
        // Scramble Logic
        document
            .querySelectorAll(".photo-card-wrapper")
            .forEach((cardWrapper) => {
                const card = cardWrapper as HTMLElement;
                const filenameEl = card.querySelector(
                    ".filename-scramble",
                ) as HTMLElement;

                // Wrapper scope for listeners
                const wrapper = card;

                if (filenameEl) {
                    // Trigger only on first hover
                    const onMouseEnter = () => {
                        unscrambleText(filenameEl);
                        card.removeEventListener("mouseenter", onMouseEnter);
                    };
                    card.addEventListener("mouseenter", onMouseEnter);
                }
            });

        // Loupe Logic
        const wrappers = document.querySelectorAll(".photo-card-wrapper");
        wrappers.forEach((cardWrapper) => {
            if (cardWrapper.hasAttribute("data-loupe-init")) return;
            cardWrapper.setAttribute("data-loupe-init", "true");

            const wrapper = cardWrapper as HTMLElement;
            const link = wrapper.querySelector("a");
            const img = wrapper.querySelector("div.z-0 img");
            const loupeContainer = wrapper.querySelector(
                ".loupe-container",
            ) as HTMLElement;
            const loupeImg = loupeContainer?.querySelector(
                "img",
            ) as HTMLImageElement;

            if (!link || !img || !loupeContainer || !loupeImg) return;

            let isShiftPressed = false;
            let zoomLevel = 1;
            let lastX = 0;
            let lastY = 0;

            const checkShift = (e: KeyboardEvent) => {
                isShiftPressed = e.shiftKey;
                if (!isShiftPressed) {
                    loupeContainer.style.display = "none";
                    link.style.cursor = "crosshair";
                } else if (link.matches(":hover")) {
                    link.style.cursor = "none";
                }
            };

            window.addEventListener("keydown", checkShift);
            window.addEventListener("keyup", checkShift);

            link.addEventListener("mousemove", (e) => {
                if (!e.shiftKey) {
                    loupeContainer.style.display = "none";
                    link.style.cursor = "crosshair";
                    return;
                }

                // Lazy load
                if (!loupeImg.src) {
                    loupeImg.src = loupeImg.getAttribute("data-src") || "";
                }

                loupeContainer.style.display = "block";
                link.style.cursor = "none";

                loupeContainer.style.left = `${e.clientX}px`;
                loupeContainer.style.top = `${e.clientY}px`;

                const rect = img.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                lastX = x / rect.width;
                lastY = y / rect.height;

                const realWidth = parseInt(link.dataset.pswpWidth || "2500");
                const realHeight = parseInt(link.dataset.pswpHeight || "1667");

                loupeImg.style.width = `${realWidth * zoomLevel}px`;
                loupeImg.style.height = `${realHeight * zoomLevel}px`;

                loupeImg.style.left = `-${lastX * realWidth * zoomLevel - 128}px`;
                loupeImg.style.top = `-${lastY * realHeight * zoomLevel - 128}px`;
            });

            link.addEventListener(
                "wheel",
                (e) => {
                    if (!isShiftPressed) return;
                    e.preventDefault();

                    const delta = -Math.sign(e.deltaY) * 0.5;
                    zoomLevel = Math.max(1, Math.min(5, zoomLevel + delta));

                    if (loupeContainer.style.display !== "none") {
                        const realWidth = parseInt(
                            link.dataset.pswpWidth || "2500",
                        );
                        const realHeight = parseInt(
                            link.dataset.pswpHeight || "1667",
                        );

                        loupeImg.style.width = `${realWidth * zoomLevel}px`;
                        loupeImg.style.height = `${realHeight * zoomLevel}px`;

                        loupeImg.style.left = `-${lastX * realWidth * zoomLevel - 128}px`;
                        loupeImg.style.top = `-${lastY * realHeight * zoomLevel - 128}px`;
                    }
                },
                { passive: false },
            );

            link.addEventListener("mouseleave", () => {
                loupeContainer.style.display = "none";
            });

            link.addEventListener(
                "click",
                (e) => {
                    if (e.shiftKey) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                    // Mobile Tap: Toggle HUD
                    wrapper.classList.toggle("mobile-active");
                },
                true,
            );

            // Touch Support
            let isLongPress = false;
            let timer: NodeJS.Timeout;

            const updateLoupePosition = (touch: Touch | MouseEvent) => {
                const rect = img.getBoundingClientRect();
                const x = touch.clientX - rect.left;
                const y = touch.clientY - rect.top;

                if (x < 0 || y < 0 || x > rect.width || y > rect.height) return;

                loupeContainer.style.left = `${touch.clientX}px`;
                loupeContainer.style.top = `${touch.clientY - 80}px`;

                const xPct = x / rect.width;
                const yPct = y / rect.height;

                const realWidth = parseInt(link.dataset.pswpWidth || "2500");
                const realHeight = parseInt(link.dataset.pswpHeight || "1667");

                loupeImg.style.width = `${realWidth * zoomLevel}px`;
                loupeImg.style.height = `${realHeight * zoomLevel}px`;

                loupeImg.style.left = `-${xPct * realWidth * zoomLevel - 128}px`;
                loupeImg.style.top = `-${yPct * realHeight * zoomLevel - 128}px`;
            };

            const onTouchStart = (e: TouchEvent) => {
                isLongPress = false;
                timer = setTimeout(() => {
                    isLongPress = true;
                    if (!loupeImg.src)
                        loupeImg.src = loupeImg.getAttribute("data-src") || "";
                    loupeContainer.style.display = "block";
                    link.style.cursor = "none";
                    updateLoupePosition(e.touches[0]);
                }, 500);
            };

            const onTouchEnd = () => {
                clearTimeout(timer);
                loupeContainer.style.display = "none";
                link.style.cursor = "crosshair";
            };

            const onTouchMove = (e: TouchEvent) => {
                if (isLongPress) {
                    if (e.cancelable) e.preventDefault();
                    updateLoupePosition(e.touches[0]);
                } else {
                    clearTimeout(timer);
                }
            };

            link.addEventListener("touchstart", onTouchStart, {
                passive: true,
            });
            link.addEventListener("touchend", onTouchEnd);
            link.addEventListener("touchmove", onTouchMove, { passive: false });
        });
    };

    initCards();
    document.addEventListener("astro:page-load", initCards);
</script>
