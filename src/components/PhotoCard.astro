---
import StaticImage from "./StaticImage.astro";

interface Props {
    photo: any;
}

const { photo } = Astro.props;
const {
    url,
    key,
    width,
    height,
    make,
    model,
    dateTaken,
    fNumber,
    iso,
    exposureTime,
    lensModel,
    focalLength,
} = photo.data;

const camera = make && model ? `${make} ${model}` : model || make || "";
const date = new Date(dateTaken).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
const aperture = fNumber ? `f/${fNumber}` : "";
const isoVal = iso ? `ISO ${iso}` : "";
const shutter = exposureTime
    ? exposureTime < 1
        ? `1/${Math.round(1 / exposureTime)}`
        : `${exposureTime}s`
    : "";
const lens = lensModel || "";
const focalLen = focalLength ? `${Math.round(focalLength)}mm` : "";
const fileName = key.split("/").pop() || key;
const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
const scramble = (text: string) => {
    return text
        .split("")
        .map((char) => {
            if (char === " " || char === ".") return char;
            return chars[Math.floor(Math.random() * chars.length)];
        })
        .join("");
};
const scrambledFileName = scramble(fileName);
---

<div class="break-inside-avoid mb-8">
    <a
        href={url}
        data-pswp-width={width || 2500}
        data-pswp-height={height || 1667}
        target="_blank"
        data-pswp-name={fileName}
        data-pswp-camera={camera}
        data-pswp-date={date}
        data-pswp-aperture={aperture}
        data-pswp-iso={isoVal}
        data-pswp-shutter={shutter}
        data-pswp-lens={lens}
        data-pswp-focal-length={focalLen}
        data-pswp-focal-length={focalLen}
        class="block group bg-neutral-900 border border-neutral-800 hover:border-neutral-600 transition-colors duration-300 sharp photo-card-container"
    >
        {/* Image Container */}
        <div class="overflow-hidden relative">
            <StaticImage
                src={url}
                alt={key}
                class="w-full h-auto block"
                imgClass="object-cover transition-transform duration-700 group-hover:scale-105 filter grayscale-0 contrast-110"
                loading="lazy"
                width={width}
                height={height}
            />
        </div>

        {/* Metadata Footer */}
        <div
            class="p-3 bg-neutral-950 border-t border-neutral-800 flex justify-between items-center"
        >
            <span
                class="text-[10px] text-neutral-400 font-mono uppercase tracking-widest truncate max-w-[60%] filename-scramble"
                data-real-value={fileName}
            >
                {scrambledFileName}
            </span>
            <div class="flex gap-4 items-center">
                <span
                    class="text-[10px] text-[var(--color-trust)] font-mono uppercase tracking-widest iso-count"
                    data-prefix="ISO "
                    data-value={iso || "RAW"}
                >
                    ISO 0
                </span>
                <span
                    class="text-[10px] text-neutral-600 font-mono uppercase tracking-widest hidden sm:inline shutter-count"
                    data-value={shutter}
                >
                    0s
                </span>
            </div>
        </div>
    </a>
</div>

<script>
    const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";

    // Scramble / Decrypt Effect
    const unscrambleText = (element: HTMLElement) => {
        const originalText = element.getAttribute("data-real-value");
        if (!originalText) return;

        let iterations = 0;
        const interval = setInterval(() => {
            element.innerText = originalText
                .split("")
                .map((char, index) => {
                    if (index < iterations) {
                        return originalText[index];
                    }
                    return CHARS[Math.floor(Math.random() * CHARS.length)];
                })
                .join("");

            if (iterations >= originalText.length) {
                clearInterval(interval);
                element.innerText = originalText; // Ensure final state is clean
            }

            iterations += 1 / 3; // Speed control
        }, 30);
    };

    // Number Scroll Effect (Generic for ISO/Shutter)
    const scrollNumber = (element: HTMLElement) => {
        const targetValue = element.getAttribute("data-value");
        if (!targetValue) return;

        // Parse number if possible, else just show text
        // ISO is usually integer. Shutter is 1/xxx or xs.
        // If it's a number, animate it. If it involves text (like "1/500"), we can't easily animate numerically linearly without custom logic.
        // User asked for "scrolling effect".
        // For shutter speed like "1/500", maybe scroll the denominator?
        // Or just random shuffle characters until it settles?
        // User said "Total Holdings to have a number scroll... ISO and shutter to finish scrolling".
        // I will use character shuffle (scramble) for non-numeric complex strings, and number count for pure numbers.

        const prefix = element.getAttribute("data-prefix") || "";

        // Check if pure number
        const numeric = parseInt(targetValue);

        if (!isNaN(numeric) && targetValue.match(/^\d+$/)) {
            let start = 0;
            const duration = 1000;
            const startTime = performance.now();

            const update = (now: number) => {
                const progress = Math.min((now - startTime) / duration, 1);
                const ease = 1 - Math.pow(1 - progress, 3); // Cubic out

                const current = Math.floor(start + (numeric - start) * ease);
                element.innerText = prefix + current;

                if (progress < 1) requestAnimationFrame(update);
                else element.innerText = prefix + targetValue;
            };
            requestAnimationFrame(update);
        } else {
            // Complex string (1/500), use scramble effect
            // Actually, reuse the unscramble logic but maybe faster?
            // Let's implement a simple random shuffle that resolves.
            let iterations = 0;
            const interval = setInterval(() => {
                element.innerText =
                    prefix +
                    targetValue
                        .split("")
                        .map((char, index) => {
                            if (index < iterations) return targetValue[index];
                            if (char === "/" || char === " " || char === "s")
                                return char;
                            return Math.floor(Math.random() * 10).toString();
                        })
                        .join("");

                if (iterations >= targetValue.length) {
                    clearInterval(interval);
                    element.innerText = prefix + targetValue;
                }
                iterations += 1 / 2;
            }, 30);
        }
    };

    // Global observer or loop
    // Since scripts run once, we query all containers.
    // Important: View Transitions or Astro page swaps might re-run scripts?
    // Standard Astro: scripts run once on initial load.

    const initCards = () => {
        const cards = document.querySelectorAll(".photo-card-container");

        cards.forEach((card) => {
            if (card.hasAttribute("data-init")) return;
            card.setAttribute("data-init", "true");

            const img = card.querySelector("img");
            const filenameEl = card.querySelector(
                ".filename-scramble",
            ) as HTMLElement;
            const isoEl = card.querySelector(".iso-count") as HTMLElement;
            const shutterEl = card.querySelector(
                ".shutter-count",
            ) as HTMLElement;

            if (!img) return;

            const trigger = () => {
                if (filenameEl) unscrambleText(filenameEl);
                if (isoEl) scrollNumber(isoEl);
                if (shutterEl) scrollNumber(shutterEl);
            };

            if (img.complete) {
                // If already loaded, trigger immediately (maybe with small delay for effect)
                setTimeout(trigger, 100);
            } else {
                img.addEventListener("load", trigger);
            }
        });
    };

    // Run on load
    initCards();

    // Attempt to run on view transitions if enabled
    document.addEventListener("astro:page-load", initCards);
</script>
