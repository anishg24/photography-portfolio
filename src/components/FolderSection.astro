---
import PhotoCard from "./PhotoCard.astro";

interface Props {
    folder: string;
    folderPhotos: any[];
    collectionId: string;
}

const { folder, folderPhotos, collectionId } = Astro.props;

// Date range calculation
const dates = folderPhotos.map((p) => new Date(p.data.dateTaken).getTime());
const minDate = new Date(Math.min(...dates));
const maxDate = new Date(Math.max(...dates));

const formatDate = (d: Date) =>
    d
        .toLocaleDateString("en-US", {
            month: "2-digit",
            day: "2-digit",
            year: "numeric",
        })
        .replace(/\//g, ".");

const isSameDay = minDate.toDateString() === maxDate.toDateString();

const dateRange =
    isSameDay || dates.length < 2
        ? formatDate(minDate)
        : formatDate(minDate) + " -> " + formatDate(maxDate);

const slug = folder.toLowerCase().replace(/\s+/g, "-");
---

<section id={slug} class="scroll-mt-32 lg:scroll-mt-24 section-folder">
    {/* Section Header */}
    <div class="mb-24 flex flex-col md:flex-row justify-between items-start md:items-end w-full">
        <div class="md:w-1/2">
            <h2
                class="text-4xl lg:text-7xl font-serif text-[var(--color-on-surface)] font-bold tracking-tight uppercase leading-none"
            >
                {folder}
            </h2>
        </div>
        
        {/* The 'Void' is created by justifying the ends and restricting widths */}
        
        <div class="text-right hidden sm:block md:w-1/3 flex flex-col items-end pt-4 md:pt-0">
            <p
                class="text-sm text-[var(--color-primary-container)] font-mono uppercase tracking-[0.2em] mb-1 leading-none"
            >
                [ ID: {collectionId} ]
            </p>
            <p
                class="text-xs text-[var(--color-on-surface-variant)] font-mono uppercase tracking-[0.1em]"
            >
                {dateRange}
            </p>
        </div>
    </div>

    {/* Masonry Grid */}
    <div class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
        {folderPhotos.map((photo) => <PhotoCard photo={photo} />)}
    </div>
</section>
