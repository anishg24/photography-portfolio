---
import PhotoCard from "./PhotoCard.astro";

interface Props {
    folder: string;
    folderPhotos: any[];
    collectionId: string;
}

const { folder, folderPhotos, collectionId } = Astro.props;

// Date range calculation
const dates = folderPhotos.map((p) => new Date(p.data.dateTaken).getTime());
const minDate = new Date(Math.min(...dates));
const maxDate = new Date(Math.max(...dates));

const formatDate = (d: Date) =>
    d
        .toLocaleDateString("en-US", {
            month: "2-digit",
            day: "2-digit",
            year: "numeric",
        })
        .replace(/\//g, ".");

const isSameDay = minDate.toDateString() === maxDate.toDateString();

const dateRange =
    isSameDay || dates.length < 2
        ? formatDate(minDate)
        : formatDate(minDate) + " -> " + formatDate(maxDate);

const slug = folder.toLowerCase().replace(/\s+/g, "-");
---

<section id={slug} class="scroll-mt-32 lg:scroll-mt-24 section-folder">
    {/* Section Header */}
    <div
        class="border-b border-[var(--color-structural)] pb-4 mb-12 flex justify-between items-end"
    >
        <div>
            <h2
                class="text-4xl lg:text-5xl font-serif text-white font-bold tracking-tight uppercase"
            >
                {folder}
            </h2>
        </div>
        <div class="text-right hidden sm:block">
            <p
                class="text-xs text-[var(--color-trust)] font-mono uppercase tracking-widest mb-1"
            >
                Collection ID: {collectionId}
            </p>
            <p
                class="text-xs text-neutral-500 font-mono uppercase tracking-widest"
            >
                {dateRange}
            </p>
        </div>
    </div>

    {/* Masonry Grid */}
    <div class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
        {folderPhotos.map((photo) => <PhotoCard photo={photo} />)}
    </div>
</section>
