---
interface Props {
    sortedFolders: string[];
    totalPhotos: number;
}

const { sortedFolders, totalPhotos } = Astro.props;
---

<nav
    class="hidden lg:flex lg:w-72 lg:h-screen lg:sticky lg:top-0 p-0 flex-row border-r border-[var(--color-structural)] bg-[var(--color-obsidian)] z-50"
>
    {/* Left Column: Vertical Marquee Strip */}
    <div
        class="w-12 h-full border-r border-[var(--color-structural)] overflow-hidden relative flex flex-col justify-center items-center bg-black/20"
    >
        <div class="h-full overflow-hidden w-full relative">
            <div
                class="absolute inset-0 flex flex-col items-center animate-vertical-marquee"
            >
                {/* Group 1 */}
                <div class="flex flex-col gap-8 shrink-0 items-center">
                    {
                        Array.from({ length: 12 }).map(() => (
                            <span class="vertical-text text-3xl font-serif font-bold tracking-[0.2em] text-neutral-700 hover:text-white transition-colors duration-300 whitespace-nowrap cursor-default select-none">
                                ANISH PHOTOGRAPHY
                            </span>
                        ))
                    }
                </div>
                {/* Group 2 (Duplicate for loop) */}
                <div class="flex flex-col gap-8 shrink-0 items-center">
                    {
                        Array.from({ length: 12 }).map(() => (
                            <span class="vertical-text text-3xl font-serif font-bold tracking-[0.2em] text-neutral-700 hover:text-white transition-colors duration-300 whitespace-nowrap cursor-default select-none">
                                ANISH PHOTOGRAPHY
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    {/* Right Column: Main Content */}
    <div class="flex-1 flex flex-col p-8 relative">
        <div class="relative pl-0 mt-8">
            {/* Vertical Track */}
            <div class="absolute left-0 top-0 bottom-0 w-px bg-neutral-900">
            </div>

            {/* Blue Marker Indicator (Sharp) */}
            <div
                id="active-pill"
                class="absolute -left-[1px] w-[3px] bg-[var(--color-trust)] transition-all duration-300 ease-out opacity-0 z-10 hidden lg:block"
                style="height: 0px; top: 0px;"
            >
            </div>

            <ul class="space-y-4 relative z-0">
                {
                    sortedFolders.map((folder) => {
                        const slug = folder.toLowerCase().replace(/\s+/g, "-");
                        return (
                            <li>
                                <a
                                    href={`#${slug}`}
                                    class="nav-link block pl-6 text-neutral-500 hover:text-white transition-colors duration-200 text-xs font-mono uppercase tracking-widest"
                                    data-target={slug}
                                >
                                    {folder}
                                </a>
                            </li>
                        );
                    })
                }
            </ul>
        </div>

        {/* Financial Footer */}
        <div class="mt-auto border-t border-[var(--color-structural)] pt-6">
            <div
                class="flex justify-between items-center text-[10px] font-mono text-neutral-600 uppercase tracking-wider"
            >
                <span>TOTAL HOLDINGS</span>
                <span id="total-holdings-count" data-target={totalPhotos}
                    >0</span
                >
            </div>
            <div
                class="flex justify-between items-center text-[10px] font-mono text-[var(--color-trust)] uppercase tracking-wider mt-1"
            >
                <span>MARKET STATUS</span>
                <span>LIVE</span>
            </div>
        </div>
    </div>

    <script>
        // Number Count Animation
        const counter = document.getElementById("total-holdings-count");
        if (counter) {
            const target = parseInt(counter.getAttribute("data-target") || "0");
            const duration = 2000; // 2 seconds
            const startTime = performance.now();

            const updateCount = (currentTime: number) => {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);

                // Ease out quart
                const ease = 1 - Math.pow(1 - progress, 4);

                const current = Math.floor(target * ease);
                counter.innerText = current.toString();

                if (progress < 1) {
                    requestAnimationFrame(updateCount);
                } else {
                    counter.innerText = target.toString();
                }
            };

            requestAnimationFrame(updateCount);
        }
    </script>
</nav>

<style>
    .vertical-text {
        writing-mode: vertical-lr; /* Reads top to bottom, lines go left to right */
        /* To read bottom to top, use rotate */
        transform: rotate(180deg);
        text-orientation: mixed;
    }

    .animate-vertical-marquee {
        animation: scrollUp 90s linear infinite;
    }

    /* Scroll from 0 (bottom of track due to rotation?) to -50% */
    /* Wait, standard flow is top-down. */
    /* If flex-col, content flows down. */
    /* To visually scroll "up" (bottom to top), we need to translate Y from 0 to -50%? No that moves content UP visually. YES. */

    @keyframes scrollUp {
        from {
            transform: translateY(0);
        }
        to {
            transform: translateY(-50%);
        }
    }
</style>
