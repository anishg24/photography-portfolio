---
interface Props {
    sortedFolders: string[];
    totalPhotos: number;
}

const { sortedFolders, totalPhotos } = Astro.props;
---

<nav
    class="hidden lg:flex lg:w-72 lg:h-screen lg:sticky lg:top-0 p-0 flex-row bg-[var(--color-surface-container-low)] z-50 transition-colors duration-300"
>
    {/* Left Column: Vertical Marquee Strip */}
    <div
        class="w-12 h-full overflow-hidden relative flex flex-col justify-center items-center bg-[var(--color-surface-container-lowest)]"
    >
        <div class="h-full overflow-hidden w-full relative">
            <div
                class="absolute inset-0 flex flex-col items-center animate-vertical-marquee"
            >
                {/* Group 1 */}
                <div class="flex flex-col gap-0 shrink-0 items-center">
                    {
                        Array.from({ length: 12 }).map(() => (
                            <span class="vertical-text text-3xl font-mono font-bold tracking-[0.2em] text-[var(--color-surface-container-highest)] hover:text-[var(--color-primary)] transition-colors duration-300 whitespace-nowrap cursor-default select-none py-12">
                                ANISH PHOTOGRAPHY&nbsp;&nbsp;
                            </span>
                        ))
                    }
                </div>
                {/* Group 2 (Duplicate for loop) */}
                <div class="flex flex-col gap-0 shrink-0 items-center">
                    {
                        Array.from({ length: 12 }).map(() => (
                            <span class="vertical-text text-3xl font-mono font-bold tracking-[0.2em] text-[var(--color-surface-container-highest)] hover:text-[var(--color-primary)] transition-colors duration-300 whitespace-nowrap cursor-default select-none py-12">
                                ANISH PHOTOGRAPHY&nbsp;&nbsp;
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    {/* Right Column: Main Content */}
    <div class="flex-1 flex flex-col p-8 relative">
        <div class="relative pl-0 mt-8">
            {/* Blue Marker Indicator (Sharp) */}
            <div
                id="active-pill"
                class="absolute -left-[1px] w-[3px] bg-[var(--color-primary-container)] transition-all duration-300 ease-out opacity-0 z-10 hidden lg:block"
                style="height: 0px; top: 0px;"
            >
            </div>

            <ul class="space-y-4 relative z-0">
                {
                    sortedFolders.map((folder) => {
                        const slug = folder.toLowerCase().replace(/\s+/g, "-");
                        return (
                            <li>
                                <a
                                    href={`#${slug}`}
                                    class="nav-link block pl-6 text-[var(--color-on-surface-variant)] hover:text-[var(--color-primary)] transition-colors duration-200 text-xs font-mono uppercase tracking-widest relative group flex items-center h-8"
                                    data-target={slug}
                                >
                                    {/* Progress Bar Container - Fixed Width */}
                                    <span class="absolute left-0 top-0 bottom-0 w-full opacity-10 pointer-events-none z-0">
                                        <span class="block h-full bg-[var(--color-primary-container)] w-0 transition-all duration-100 ease-linear nav-progress-bar" />
                                    </span>
                                    <span class="relative z-10">{folder}</span>
                                </a>
                            </li>
                        );
                    })
                }
            </ul>
        </div>

        {/* Financial Footer -> Tactical Status Ribbon */}
        <div class="mt-auto pt-6">
            <div
                class="flex justify-between items-center text-[10px] font-mono text-[var(--color-on-surface-variant)] uppercase tracking-wider"
            >
                <span>TOTAL HOLDINGS</span>
                <span id="total-holdings-count" data-target={totalPhotos} class="text-[var(--color-on-surface)]"
                    >0</span
                >
            </div>
            <div
                class="flex justify-between items-center text-[10px] font-mono uppercase tracking-wider mt-1"
            >
                <span class="text-[var(--color-primary)]">SYSTEM STATUS</span>
                <span id="market-status" class="text-[var(--color-primary-container)]"
                    >LIVE</span
                >
            </div>
        </div>
    </div>

    <script>
        // Number Count Animation
        const counter = document.getElementById("total-holdings-count");
        if (counter) {
            const target = parseInt(counter.getAttribute("data-target") || "0");
            const duration = 2000; // 2 seconds
            const startTime = performance.now();

            const updateCount = (currentTime: number) => {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);

                // Ease out quart
                const ease = 1 - Math.pow(1 - progress, 4);

                const current = Math.floor(target * ease);
                counter.innerText = current.toString();

                if (progress < 1) {
                    requestAnimationFrame(updateCount);
                } else {
                    counter.innerText = target.toString();
                }
            };

            requestAnimationFrame(updateCount);
        }

        // Smart Active State Progress
        document.addEventListener("section-progress", ((e: CustomEvent) => {
            const { sectionId, progress } = e.detail;

            // Reset others
            document.querySelectorAll(".nav-progress-bar").forEach((el) => {
                const parent = el.closest(".nav-link");
                if (
                    parent &&
                    parent.getAttribute("data-target") !== sectionId
                ) {
                    (el as HTMLElement).style.width = "0%";
                }
            });

            // Update active
            const activeLink = document.querySelector(
                `.nav-link[data-target="${sectionId}"] .nav-progress-bar`,
            ) as HTMLElement;
            if (activeLink) {
                // Ensure smooth 0-100 fill
                activeLink.style.width = `${Math.max(0, Math.min(100, progress * 100))}%`;
            }
        }) as EventListener);

        // Market Status Logic
        function updateMarketStatus() {
            const statusElement = document.getElementById("market-status");
            if (!statusElement) return;

            const now = new Date();
            const nyTime = new Date(
                now.toLocaleString("en-US", { timeZone: "America/New_York" }),
            );

            const day = nyTime.getDay(); // 0 is Sunday, 6 is Saturday
            const hour = nyTime.getHours();
            const minute = nyTime.getMinutes();

            // Market Hours: Mon-Fri, 9:30 AM - 4:00 PM
            const isWeekend = day === 0 || day === 6;
            const isMarketHours =
                (hour > 9 && hour < 16) || (hour === 9 && minute >= 30);

            const isOpen = !isWeekend && isMarketHours;

            statusElement.innerText = isOpen ? "LIVE" : "OFFLINE";

            // Optional: Update color based on status
            if (isOpen) {
                statusElement.classList.remove("text-neutral-500");
                statusElement.classList.add("text-[var(--color-trust)]");
            } else {
                statusElement.classList.remove("text-[var(--color-trust)]");
                statusElement.classList.add("text-neutral-500");
            }
        }

        // Run immediately and update every minute
        updateMarketStatus();
        setInterval(updateMarketStatus, 60000);
    </script>
</nav>

<style>
    .vertical-text {
        writing-mode: vertical-lr; /* Reads top to bottom, lines go left to right */
        /* To read bottom to top, use rotate */
        transform: rotate(180deg);
        text-orientation: mixed;
    }

    .animate-vertical-marquee {
        animation: scrollUp 40s linear infinite;
    }

    /* Scroll from 0 (bottom of track due to rotation?) to -50% */
    /* Wait, standard flow is top-down. */
    /* If flex-col, content flows down. */
    /* To visually scroll "up" (bottom to top), we need to translate Y from 0 to -50%? No that moves content UP visually. YES. */

    @keyframes scrollUp {
        from {
            transform: translateY(0);
        }
        to {
            transform: translateY(-50%);
        }
    }
</style>
