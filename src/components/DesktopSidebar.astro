---
interface Props {
    sortedFolders: string[];
    totalPhotos: number;
}

const { sortedFolders, totalPhotos } = Astro.props;
---

<nav
    class="hidden lg:flex lg:w-72 lg:h-screen lg:sticky lg:top-0 p-8 flex-col border-r border-neutral-800 bg-[var(--color-obsidian)] z-50"
>
    <h1
        class="text-3xl font-serif font-bold tracking-tighter text-white uppercase mb-16"
    >
        Anish<br />Photography
    </h1>

    <div class="relative pl-0">
        {/* Vertical Track */}
        <div class="absolute left-0 top-0 bottom-0 w-px bg-neutral-900"></div>

        {/* Blue Marker Indicator (Sharp) */}
        <div
            id="active-pill"
            class="absolute -left-[1px] w-[3px] bg-[var(--color-trust)] transition-all duration-300 ease-out opacity-0 z-10 hidden lg:block"
            style="height: 0px; top: 0px;"
        >
        </div>

        <ul class="space-y-4 relative z-0">
            {
                sortedFolders.map((folder) => {
                    const slug = folder.toLowerCase().replace(/\s+/g, "-");
                    return (
                        <li>
                            <a
                                href={`#${slug}`}
                                class="nav-link block pl-6 text-neutral-500 hover:text-white transition-colors duration-200 text-xs font-mono uppercase tracking-widest"
                                data-target={slug}
                            >
                                {folder}
                            </a>
                        </li>
                    );
                })
            }
        </ul>
    </div>

    {/* Financial Footer */}
    <div class="mt-auto border-t border-neutral-900 pt-6">
        <div
            class="flex justify-between items-center text-[10px] font-mono text-neutral-600 uppercase tracking-wider"
        >
            <span>TOTAL HOLDINGS</span>
            <span>{totalPhotos}</span>
        </div>
        <div
            class="flex justify-between items-center text-[10px] font-mono text-[var(--color-trust)] uppercase tracking-wider mt-1"
        >
            <span>MARKET STATUS</span>
            <span>LIVE</span>
        </div>
    </div>
</nav>
