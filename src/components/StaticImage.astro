---
import { Image } from "astro:assets";

interface Props extends astroHTML.JSX.ImgHTMLAttributes {
    class?: string;
    imgClass?: string;
}

const { class: className, imgClass, ...props } = Astro.props;
---

<div class:list={["static-image-wrapper", className]}>
    <div class="pulsing-placeholder"></div>
    <Image
        class:list={[imgClass, "smooth-image"]}
        width={props.width as number}
        height={props.height as number}
        {...props as any}
        onload="this.parentElement.classList.add('loaded')"
    />
</div>

<style>
    .static-image-wrapper {
        position: relative;
        overflow: hidden;
        display: block;
        background-color: #0a0a0a; /* Matches neutral-950 */
    }

    .pulsing-placeholder {
        position: absolute;
        inset: 0;
        z-index: 10;
        pointer-events: none;
        background-color: #262626; /* neutral-800: Subtle lighter gray */
        opacity: 0.4;
        /* Continuous breathing animation */
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .smooth-image {
        display: block;
        width: 100%;
        height: auto;
        opacity: 0;
        /* Handle both transform and specific scale property for compatibility */
        transition:
            opacity 0.8s ease-out 0.2s,
            transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0s,
            scale 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0s;
    }

    /* Loaded State Logic */
    .static-image-wrapper.loaded .pulsing-placeholder {
        /* Switch to the final "one last pulse" sequence */
        animation: final-pulse 0.8s ease-out forwards;
    }

    .static-image-wrapper.loaded .smooth-image {
        opacity: 1;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 0.3;
        }
        50% {
            opacity: 0.6;
        }
    }

    @keyframes final-pulse {
        0% {
            opacity: 0.5; /* Approximate current state to minimize jump */
        }
        30% {
            opacity: 0.9; /* intense peak */
            background-color: #404040; /* Slightly lighter for the flash */
        }
        100% {
            opacity: 0;
        }
    }
</style>
