---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import ReactGallery from "../components/ReactGallery";
import MobileHeader from "../components/MobileHeader.astro";
import DesktopSidebar from "../components/DesktopSidebar.astro";
import MobileFooter from "../components/MobileFooter.astro";
import { getCollection } from "astro:content";

// Fetch photos from local portfolio collection
const photos = await getCollection("portfolio");

// Group photos by folder (album) instead of year
const groupedPhotos: Record<string, typeof photos> = {};

photos.forEach((photo) => {
	// e.g. "San Diego Zoo/PIC.jpg" -> "San Diego Zoo"
	const folderParts = photo.id.split("/");
	const folderRaw = folderParts.length > 1 ? folderParts[0] : "Ungrouped";
	const folder = folderRaw.replace(/-/g, ' ');

	if (!groupedPhotos[folder]) {
		groupedPhotos[folder] = [];
	}
	groupedPhotos[folder].push(photo);
});

// Function to get the latest date in a folder
const getFolderDate = (folder: string) => {
	const dates = groupedPhotos[folder].map(p => p.data.date ? new Date(p.data.date).getTime() : 0);
	return Math.max(...dates);
};

// Sort folders chronologically (newest first)
const sortedFolders = Object.keys(groupedPhotos).sort((a, b) => {
	if (a === "Ungrouped") return 1;
	if (b === "Ungrouped") return -1;
	return getFolderDate(b) - getFolderDate(a);
});

// Sort photos within folders (newest first)
sortedFolders.forEach((folder) => {
	groupedPhotos[folder].sort(
		(a, b) => {
            const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
            const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
            return dateB - dateA;
        }
	);
});

const generateCollectionId = (folderName: string) => {
	// Split by space or special characters
	const words = folderName.split(/[\s_-]+/);

	if (words.length === 1) {
		return folderName.substring(0, 3).toUpperCase();
	}

	// Initials
	let initials = words
		.map((w) => w[0])
		.join("")
		.toUpperCase();

	// If only 2 letters, maybe different logic? User asked for Distinct.
	// E.g. San Diego -> SD. San Diego Zoo -> SDZ.
	return initials;
};
---

<Layout title="Anish Photography">
	<div
		class="flex flex-col lg:flex-row min-h-screen bg-[var(--color-surface)] text-[var(--color-on-surface-variant)]"
	>
		<MobileHeader sortedFolders={sortedFolders} />

		<DesktopSidebar
			sortedFolders={sortedFolders}
			totalPhotos={photos.length}
		/>

		{/* Main Content */}
		<main class="flex-1 p-4 lg:p-12 ml-0 w-full bg-[var(--color-surface)]">
			{
				Object.keys(groupedPhotos).length === 0 ? (
					<div class="text-center py-20">
						<p class="text-neutral-500 font-mono">
							NO_DATA_AVAILABLE // UPLOAD_TO_R2
						</p>
					</div>
				) : (
                    <ReactGallery 
                        client:load 
                        groupedPhotos={groupedPhotos} 
                        sortedFolders={sortedFolders} 
                    />
				)
			}
		</main>

		<MobileFooter totalPhotos={photos.length} />
	</div>

	<script>
		import { WebHaptics } from "web-haptics";
		const haptics = new WebHaptics();


		// Intersection Observer for Active State
		const sections = document.querySelectorAll(".section-folder");
		const navLinks = document.querySelectorAll(".nav-link");
		const pill = document.getElementById("active-pill");

		const observerOptions = {
			root: null,
			rootMargin: "-25% 0px -50% 0px", // Adjusted for mobile sticky header
			threshold: 0,
		};

		let activeSectionId: string | null = null;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const id = entry.target.id;

					if (activeSectionId && activeSectionId !== id) {
						haptics.trigger("heavy");
					}
					activeSectionId = id;

					// Reset and activate all links pointing to this target (mobile + desktop)
					navLinks.forEach((link) => {
						const target = link.getAttribute("data-target");
						if (target === id) {
							link.classList.remove("text-neutral-500");
							link.classList.add("text-white");
						} else {
							link.classList.remove("text-white");
							link.classList.add("text-neutral-500");
						}
					});

					// Handle Pillar Indicator (Desktop Only)
					const desktopActiveLink = document.querySelector(
						`nav.lg\\:flex .nav-link[data-target="${id}"]`,
					) as HTMLElement;

					if (desktopActiveLink && pill && pill.offsetParent) {
						const container = pill.offsetParent as HTMLElement;
						const linkRect =
							desktopActiveLink.getBoundingClientRect();
						const containerRect = container.getBoundingClientRect();
						const relativeTop = linkRect.top - containerRect.top;
						const linkHeight = desktopActiveLink.offsetHeight;

						const targetHeight = 16;
						const offset = (linkHeight - targetHeight) / 2;

						pill.style.opacity = "1";
						pill.style.top = `${relativeTop + offset}px`;
						pill.style.height = `${targetHeight}px`;
					}
				}
			});
		}, observerOptions);

		sections.forEach((section) => {
			observer.observe(section);
		});
	</script>
</Layout>
