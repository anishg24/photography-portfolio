---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import Lightbox from "../components/Lightbox.astro";
import MobileHeader from "../components/MobileHeader.astro";
import DesktopSidebar from "../components/DesktopSidebar.astro";
import FolderSection from "../components/FolderSection.astro";
import MobileFooter from "../components/MobileFooter.astro";
import { getCollection } from "astro:content";

// Fetch photos from R2 collection
const photos = await getCollection("photos");

// Group photos by folder
const groupedPhotos: Record<string, typeof photos> = {};

photos.forEach((photo) => {
	// Extract folder name from key (e.g. "Values/img.jpg" -> "Values")
	// If no folder, use "Miscellaneous"
	const parts = photo.data.key.split("/");
	const folder = parts.length > 1 ? parts[0] : "Miscellaneous";

	if (!groupedPhotos[folder]) {
		groupedPhotos[folder] = [];
	}
	groupedPhotos[folder].push(photo);
});

// Sort folders: Alphabetical, with Miscellaneous last
// Sort folders: Chronological (newest photo first), with Miscellaneous last
const sortedFolders = Object.keys(groupedPhotos).sort((a, b) => {
	if (a === "Miscellaneous") return 1;
	if (b === "Miscellaneous") return -1;

	// Get latest date for folder A
	const photosA = groupedPhotos[a];
	const latestDateA = photosA.reduce((max, p) => {
		const d = new Date(p.data.dateTaken).getTime();
		return d > max ? d : max;
	}, 0);

	// Get latest date for folder B
	const photosB = groupedPhotos[b];
	const latestDateB = photosB.reduce((max, p) => {
		const d = new Date(p.data.dateTaken).getTime();
		return d > max ? d : max;
	}, 0);

	return latestDateB - latestDateA;
});

// Sort photos within folders (newest first)
sortedFolders.forEach((folder) => {
	groupedPhotos[folder].sort(
		(a, b) =>
			new Date(b.data.dateTaken).getTime() -
			new Date(a.data.dateTaken).getTime(),
	);
});

const generateCollectionId = (folderName: string) => {
	// Split by space or special characters
	const words = folderName.split(/[\s_-]+/);

	if (words.length === 1) {
		return folderName.substring(0, 3).toUpperCase();
	}

	// Initials
	let initials = words
		.map((w) => w[0])
		.join("")
		.toUpperCase();

	// If only 2 letters, maybe different logic? User asked for Distinct.
	// E.g. San Diego -> SD. San Diego Zoo -> SDZ.
	return initials;
};
---

<Layout title="Anish Photography">
	<div
		class="flex flex-col lg:flex-row min-h-screen bg-[var(--color-obsidian)] text-[var(--color-flash)]"
	>
		<MobileHeader sortedFolders={sortedFolders} />

		<DesktopSidebar
			sortedFolders={sortedFolders}
			totalPhotos={photos.length}
		/>

		{/* Main Content */}
		<main class="flex-1 p-4 lg:p-12 ml-0 w-full bg-[var(--color-obsidian)]">
			{
				Object.keys(groupedPhotos).length === 0 ? (
					<div class="text-center py-20">
						<p class="text-neutral-500 font-mono">
							NO_DATA_AVAILABLE // UPLOAD_TO_R2
						</p>
					</div>
				) : (
					<div class="space-y-40 pb-32 lg:pb-0">
						{sortedFolders.map((folder) => (
							<FolderSection
								folder={folder}
								folderPhotos={groupedPhotos[folder]}
								collectionId={generateCollectionId(folder)}
							/>
						))}
					</div>
				)
			}

			<Lightbox />
		</main>

		<MobileFooter totalPhotos={photos.length} />
	</div>

	<script>
		const navSections = Array.from(
			document.querySelectorAll(".section-folder"),
		);

		// Scroll Progress for Smart Active States
		window.addEventListener(
			"scroll",
			() => {
				navSections.forEach((section) => {
					const rect = section.getBoundingClientRect();
					const scrollTop = window.scrollY;
					const viewportHeight = window.innerHeight;
					const sectionTop = rect.top + scrollTop;
					const sectionHeight = rect.height;

					// Standard Read Progress: (ScrollTop - SectionTop) / (SectionHeight - ViewportHeight)
					// Adjusted so it starts 0 when section enters, 1 when section leaves?
					// Or standard article progress: 0 when top of section matches top of viewport?
					// Let's do: 0% when section top hits 1/3 viewport, 100% when section bottom hits 1/3 viewport?
					// Or simpler: (scrollTop + viewportHeight/2 - sectionTop) / sectionHeight

					// Actually, let's stick to "visible percentage" or "distance from top".
					// The user wants it to fill up as they read.
					// Start filling when the header crosses the "active threshold" (usually midway or top).
					// Let's use relative computation from the intersection observer logic.

					const distance = -rect.top; // How far section top is from viewport top. If positive, we are inside or past it.
					const progress =
						distance / (sectionHeight - viewportHeight / 2);

					if (progress >= -0.1 && progress <= 1.1) {
						document.dispatchEvent(
							new CustomEvent("section-progress", {
								detail: {
									sectionId: section.id,
									progress: Math.max(
										0,
										Math.min(1, progress),
									),
								},
							}),
						);
					}
				});
			},
			{ passive: true },
		);

		// Intersection Observer for Active State
		const sections = document.querySelectorAll(".section-folder");
		const navLinks = document.querySelectorAll(".nav-link");
		const pill = document.getElementById("active-pill");

		const observerOptions = {
			root: null,
			rootMargin: "-25% 0px -50% 0px", // Adjusted for mobile sticky header
			threshold: 0,
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const id = entry.target.id;

					// Reset and activate all links pointing to this target (mobile + desktop)
					navLinks.forEach((link) => {
						const target = link.getAttribute("data-target");
						if (target === id) {
							link.classList.remove("text-neutral-500");
							link.classList.add("text-white");
						} else {
							link.classList.remove("text-white");
							link.classList.add("text-neutral-500");
						}
					});

					// Handle Pillar Indicator (Desktop Only)
					const desktopActiveLink = document.querySelector(
						`nav.lg\\:flex .nav-link[data-target="${id}"]`,
					) as HTMLElement;

					if (desktopActiveLink && pill && pill.offsetParent) {
						const container = pill.offsetParent as HTMLElement;
						const linkRect =
							desktopActiveLink.getBoundingClientRect();
						const containerRect = container.getBoundingClientRect();
						const relativeTop = linkRect.top - containerRect.top;
						const linkHeight = desktopActiveLink.offsetHeight;

						const targetHeight = 16;
						const offset = (linkHeight - targetHeight) / 2;

						pill.style.opacity = "1";
						pill.style.top = `${relativeTop + offset}px`;
						pill.style.height = `${targetHeight}px`;
					}
				}
			});
		}, observerOptions);

		sections.forEach((section) => {
			observer.observe(section);
		});
	</script>
</Layout>
